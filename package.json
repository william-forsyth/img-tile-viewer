{
  "name": "img-tile-viewer",
  "version": "1.0.0",
  "description": "Local offline image tile viewer",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/launch.js",
    "prebuild": "node scripts/prepare-wincodesign.js",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.0.0",
    "jimp": "^1.6.1",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.wforsyth.img-tile-viewer",
    "productName": "img-viewer",
    "icon": "assets/icon.ico",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "img-viewer",
      "artifactName": "img-viewer-setup.${ext}"
    }
  }
}
